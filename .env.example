# Sage Retirement Planning Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================
# FRONTEND CONFIGURATION
# ============================================

# Backend API URL
#NEXT_PUBLIC_API_URL=http://localhost:8172
NEXT_PUBLIC_API_URL=https://white-sand-06364b01e.7.azurestaticapps.net

# Mock mode delay (milliseconds)
NEXT_PUBLIC_MOCK_DELAY=1000

# ============================================
# BACKEND CONFIGURATION (for backend/.env)
# ============================================

# Azure AI Configuration (required for live mode)
PROJECT_ENDPOINT=https://your-ai-foundry.services.ai.azure.com/api/projects/your-project
MODEL_DEPLOYMENT_NAME=gpt-4.1

# Azure AI Foundry Project Configuration (for evaluation publishing)
AZURE_SUBSCRIPTION_ID=your-azure-subscription-id
PROJECT_NAME=your-project-name
RESOURCE_GROUP_NAME=your-resource-group-name

# Azure OpenAI Configuration for Evaluations
AZURE_OPENAI_ENDPOINT=https://your-openai-instance.openai.azure.com/
AZURE_OPENAI_KEY=your-azure-openai-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_API_VERSION=2024-02-01

# Server Configuration
PORT=8172
ENVIRONMENT=development

# CORS Configuration (add your frontend domains)
CORS_ORIGINS=http://localhost:3847,https://your-frontend-domain.com

# ============================================
# DATA STORAGE CONFIGURATION
# ============================================

# Storage backend: "local" (default) or "azure"
STORAGE_BACKEND=local

# Azure Blob Storage (only required if STORAGE_BACKEND=azure)
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...

# ============================================
# FOUNDRY IQ — Azure AI Search MCP Knowledge Base
# ============================================
# Grounds advisor chat with curated knowledge (compliance, products, regulations)
# Requires an Azure AI Search resource with a Knowledge Base + MCP endpoint

SAGE_KB_MCP_URL=https://your-search.search.windows.net/knowledgebases/your-kb-name/mcp?api-version=2025-11-01-preview
SAGE_KB_MCP_API_KEY=your-search-api-key
SAGE_KB_MCP_TOOL_NAME=knowledge_base_retrieve
SAGE_KB_MCP_TIMEOUT_SECONDS=8
SAGE_KB_MCP_RETRIES=1
SAGE_KB_MCP_HEALTH_TIMEOUT_SECONDS=3

# Demo tenant for Azure AI resources (allows app to work when az cli targets a different tenant)
# DEMO_TENANT_ID=your-azure-ad-tenant-id

# ============================================
# FABRIC IQ — Microsoft Fabric Data Agent
# ============================================
# Enables natural-language queries against a Fabric Lakehouse (client & portfolio data)
# Uses a Service Principal (ClientSecretCredential) — isolated from az cli auth
# The Fabric capacity can be in a DIFFERENT tenant than the app's Azure resources

FABRIC_TENANT_ID=your-fabric-tenant-id
FABRIC_CLIENT_ID=your-spn-application-client-id
FABRIC_CLIENT_SECRET=your-spn-client-secret
# Published Data Agent URL (set after creating + publishing via Fabric notebook)
FABRIC_DATA_AGENT_URL=https://api.fabric.microsoft.com/v1/workspaces/<workspace-id>/dataagents/<agent-id>/aiassistant/openai
# Assistant ID of the published Data Agent
FABRIC_DATA_AGENT_ID=your-published-assistant-id

# ============================================
# WORK IQ — Microsoft 365 Context via MCP
# ============================================
# Enriches the advisor experience with calendar, email, file context from M365
#   "local"    = Live queries via WorkIQ CLI (requires local auth tokens)
#   "mock"     = Static mock data from backend/data/workiq_mock.json (for cloud/offline)
#   "disabled" = No WorkIQ integration
WORKIQ_MODE=disabled

